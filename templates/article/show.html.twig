{% extends 'layouts/page.html.twig' %}

{% block title %}{{ article.title }} — La Boîte à Chimère{% endblock %}

{% block description %}{{ article.title }} — Retrouvez toutes les actualités et comptes-rendus de La Boîte à Chimère.{% endblock %}

{% block page_title %}{{ article.title }}{% endblock %}
{% block page_subtitle %}
	<p class="text-lg text-text-secondary max-w-2xl mx-auto">
		Publié dans la section Dernières Chimères
	</p>
{% endblock %}

{% block content %}
<article class="max-w-3xl mx-auto rounded-2xl border border-custom glass-card p-6 lg:p-10 shadow-xl relative overflow-hidden">
    <div class="flex items-center gap-3 mb-6">
        <span class="inline-block rounded-md bg-custom-orange/10 px-2.5 py-1 text-[10px] font-bold uppercase tracking-wider text-custom-orange">{{ article.tag }}</span>
    </div>

    {% if article.image %}
        <div class="mb-8 overflow-hidden rounded-xl border border-custom max-w-xl mx-auto aspect-video relative shadow-lg shadow-black/20">
            <img src="{{ asset('images/articles/' ~ article.image) }}" alt="Illustration pour : {{ article.title }}" class="h-full w-full object-cover">
        </div>
    {% endif %}

    <div class="prose prose-invert max-w-none text-text-secondary text-sm lg:text-base leading-relaxed space-y-6">
        {{ article.content|sanitize_html }}
    </div>

    {% if article.gallery is not empty %}
        <div class="mt-12 pt-8 border-t border-custom">
            <h3 class="text-xs font-bold text-text-primary uppercase tracking-wider mb-6">Galerie photos</h3>
            <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
                {% for img in article.gallery %}
                    <div class="relative group overflow-hidden rounded-xl border border-custom bg-custom-secondary/40 aspect-[4/3] cursor-pointer shadow-md hover:shadow-custom-orange/10 hover:border-custom-orange/50 transition-all duration-300 transform hover:-translate-y-1" data-lightbox-open="{{ asset('images/articles/' ~ img) }}">
                        <img src="{{ asset('images/articles/' ~ img) }}" alt="Galerie : {{ article.title }}" class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105">
                        <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
                            <span class="text-white text-xs font-bold uppercase tracking-wider bg-custom-orange/90 px-3 py-1.5 rounded-lg shadow-lg">Agrandir</span>
                        </div>
                    </div>
                {% endfor %}
            </div>
        </div>
    {% endif %}

    <div class="mt-8 pt-6 border-t border-custom flex justify-between">
        <a href="{{ path('app_home') }}" class="text-xs text-text-secondary hover:text-custom-orange transition-colors">&larr; Retour à l'accueil</a>
    </div>
</article>

<!-- Lightbox Modal -->
{% if article.gallery is not empty %}
    <div id="lightbox" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/90 backdrop-blur-md opacity-0 transition-all duration-300 ease-out" data-lightbox-close>
        <!-- Bouton Fermer -->
        <button type="button" class="absolute top-4 right-4 z-50 p-2.5 rounded-full bg-white/10 text-white/70 hover:text-white hover:bg-white/20 transition-all cursor-pointer focus:outline-none" data-lightbox-close>
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>

        <!-- Conteneur d'image principale -->
        <div class="relative max-w-4xl max-h-[85vh] p-2 flex items-center justify-center" data-lightbox-stop>
            <img id="lightbox-img" src="" alt="Agrandissement" class="max-w-full max-h-[80vh] rounded-xl object-contain shadow-2xl border border-white/10 scale-95 transition-transform duration-300 ease-out">
        </div>
    </div>

    <script nonce="{{ csp_nonce() }}">
        window.openLightbox = function(src) {
            const lightbox = document.getElementById('lightbox');
            const img = document.getElementById('lightbox-img');

            img.src = src;
            lightbox.classList.remove('hidden');
            lightbox.classList.add('flex');
            setTimeout(() => {
                lightbox.classList.add('opacity-100');
                img.classList.remove('scale-95');
                img.classList.add('scale-100');
            }, 10);

            document.body.style.overflow = 'hidden';
        };

        window.closeLightbox = function(event) {
            if (event) event.stopPropagation();
            const lightbox = document.getElementById('lightbox');
            const img = document.getElementById('lightbox-img');
            
            img.classList.remove('scale-100');
            img.classList.add('scale-95');
            lightbox.classList.remove('opacity-100');

            setTimeout(() => {
                img.src = '';
                lightbox.classList.remove('flex');
                lightbox.classList.add('hidden');
            }, 300);

            document.body.style.overflow = '';
        };

        document.addEventListener('keydown', function(e) {
            const lightbox = document.getElementById('lightbox');
            if (lightbox && lightbox.classList.contains('opacity-100')) {
                if (e.key === 'Escape') {
                    window.closeLightbox();
                }
            }
        });
    </script>
    <style>
        #lightbox-img {
            transition: transform 0.3s ease-out, opacity 0.15s ease-in-out;
        }
    </style>
{% endif %}
{% endblock %}
