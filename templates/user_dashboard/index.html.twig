{% extends 'layouts/page.html.twig' %}

{% block title %}Mon espace - La Boîte à Chimère{% endblock %}

{% block meta_description %}<meta name="robots" content="noindex, nofollow">{% endblock %}
{% block canonical %}{% endblock %}
{% block og_tags %}{% endblock %}
{% block jsonld %}{% endblock %}

{% block page_title %}Mon espace{% endblock %}
{% block page_subtitle %}<p class="text-lg text-text-secondary max-w-2xl mx-auto">Bienvenue <span class="text-custom-orange font-bold">{{ app.user.username }}</span></p>{% endblock %}

{% block javascripts %}
	{{ parent() }}
	<script nonce="{{ csp_nonce() }}">
		function initPasswordMismatch() {
			const pwd = document.getElementById('new_password');
			const confirm = document.getElementById('confirm_password');
			const error = document.getElementById('password-mismatch');
			const form = document.getElementById('change-password-form');
			if (!pwd || !confirm || !form) return;
			
			function check() {
				if (confirm.value && pwd.value !== confirm.value) {
					error.classList.remove('hidden');
					confirm.classList.add('border-red-500');
					confirm.classList.remove('border-custom');
				} else {
					error.classList.add('hidden');
					confirm.classList.remove('border-red-500');
					confirm.classList.add('border-custom');
				}
			}
			pwd.addEventListener('input', check);
			confirm.addEventListener('input', check);
			form.addEventListener('submit', function(e) {
				if (pwd.value !== confirm.value) {
					e.preventDefault();
					error.classList.remove('hidden');
					confirm.classList.add('border-red-500');
					confirm.focus();
				}
			});
		}
		document.addEventListener('DOMContentLoaded', initPasswordMismatch);
		document.addEventListener('turbo:load', initPasswordMismatch);
	</script>
{% endblock %}

{% block content %}
	<div class="space-y-8">

		{# ── Infos du compte ── #}
		<div class="rounded-2xl border border-custom bg-custom-secondary p-6 shadow-xl glass-card mb-8">
			<h2 class="text-[10px] font-bold uppercase tracking-wider text-text-secondary mb-4">Mon compte</h2>
			<div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
				<div>
					<p class="text-[10px] font-bold uppercase tracking-wider text-text-secondary/60 mb-1">Nom d'utilisateur</p>
					<p class="text-sm font-medium text-text-primary">{{ app.user.username }}</p>
				</div>
				<div>
					<p class="text-[10px] font-bold uppercase tracking-wider text-text-secondary/60 mb-1">Email</p>
					<p class="text-sm font-medium text-text-primary">{{ app.user.email }}</p>
				</div>
				<div>
					<p class="text-[10px] font-bold uppercase tracking-wider text-text-secondary/60 mb-1">Membre depuis</p>
					<p class="text-sm font-medium text-text-primary">{{ app.user.createdAt ? app.user.createdAt|date('d/m/Y') : '—' }}</p>
				</div>
			</div>
		</div>

		{# ── Activités à venir ── #}
		<div class="mb-8">
			<h2 class="text-lg font-bold text-text-primary uppercase tracking-wide mb-4">Mes prochaines activités</h2>
			{% if upcoming|length > 0 %}
				<div class="space-y-3">
					{% for inscription in upcoming %}
						{% set activity = inscription.activity %}
						<div class="rounded-xl border border-custom bg-custom-secondary p-4 shadow-lg glass-card flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
							<div class="flex items-center gap-4">
								<div class="flex flex-col items-center justify-center rounded-lg bg-custom-orange/10 border border-custom-orange/30 px-3 py-2 min-w-[60px]">
									<span class="text-lg font-bold text-custom-orange leading-none">{{ activity.startAt|date('d') }}</span>
									<span class="text-[9px] font-bold uppercase tracking-wider text-custom-orange/70">{{ activity.startAt|date('M') }}</span>
								</div>
								<div>
									<h3 class="text-sm font-bold text-text-primary">{{ activity.title }}</h3>
									{% if activity.location %}
										<p class="text-xs text-text-secondary mt-0.5">{{ activity.location }}</p>
									{% endif %}
									{% if activity.type %}
										<span class="inline-block mt-1 text-[9px] font-bold uppercase tracking-widest px-2 py-0.5 rounded bg-custom-orange/10 text-custom-orange">{{ activity.type }}</span>
									{% endif %}
								</div>
							</div>
							<div class="flex items-center gap-3 self-start sm:self-center">
								<span class="text-[10px] font-bold uppercase tracking-wider text-emerald-400 px-3 py-1.5 rounded-lg bg-emerald-400/10 border border-emerald-400/30">
									Inscrit
								</span>
								<form method="post" action="{{ path('app_user_unregister', { id: inscription.id }) }}" onsubmit="return confirm('Se désinscrire de « {{ activity.title }} » ?');">
									<input type="hidden" name="_token" value="{{ csrf_token('unregister' ~ inscription.id) }}">
									<button type="submit" class="text-[10px] font-bold uppercase tracking-wider text-red-400 hover:text-red-300 px-3 py-1.5 rounded-lg bg-red-400/10 border border-red-400/30 hover:bg-red-400/20 transition-all">
										Se désinscrire
									</button>
								</form>
							</div>
						</div>
					{% endfor %}
				</div>
			{% else %}
				<div class="rounded-2xl border border-custom bg-custom-secondary p-8 text-center glass-card">
					<p class="text-text-secondary text-sm">Aucune activité à venir.</p>
					<a href="{{ path('app_home') }}" class="inline-block mt-3 text-[10px] font-bold uppercase tracking-wider text-custom-orange hover:text-orange-400 transition-colors">Voir le calendrier</a>
				</div>
			{% endif %}
		</div>

		{# ── Historique des participations ── #}
		<div class="mb-8">
			<h2 class="text-lg font-bold text-text-primary uppercase tracking-wide mb-4">Historique de mes participations</h2>
			{% if past|length > 0 %}
				<div class="space-y-3">
					{% for inscription in past %}
						{% set activity = inscription.activity %}
						<div class="rounded-xl border border-custom/50 bg-custom-secondary p-4 shadow-lg glass-card flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
							<div class="flex items-center gap-4">
								<div class="flex flex-col items-center justify-center rounded-lg bg-white/5 border border-custom/50 px-3 py-2 min-w-[60px]">
									<span class="text-lg font-bold text-text-secondary leading-none">{{ activity.startAt|date('d') }}</span>
									<span class="text-[9px] font-bold uppercase tracking-wider text-text-secondary/70">{{ activity.startAt|date('M Y') }}</span>
								</div>
								<div>
									<h3 class="text-sm font-bold text-text-primary">{{ activity.title }}</h3>
									{% if activity.location %}
										<p class="text-xs text-text-secondary mt-0.5">{{ activity.location }}</p>
									{% endif %}
									{% if activity.type %}
										<span class="inline-block mt-1 text-[9px] font-bold uppercase tracking-widest px-2 py-0.5 rounded bg-white/5 text-text-secondary">{{ activity.type }}</span>
									{% endif %}
								</div>
							</div>
							<div class="text-[10px] font-bold uppercase tracking-wider text-text-secondary/60 px-3 py-1.5 rounded-lg bg-white/5 border border-custom/30 self-start sm:self-center">
								Participé
							</div>
						</div>
					{% endfor %}
				</div>
			{% else %}
				<div class="rounded-2xl border border-custom bg-custom-secondary p-8 text-center glass-card">
					<p class="text-text-secondary text-sm">Aucune participation passée.</p>
				</div>
			{% endif %}
		</div>

		{# ── Ludothèque (jeux déjà empruntés) ── #}
		<div class="mb-8" id="ludotheque">
			<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 mb-4">
				<div>
					<h2 class="text-lg font-bold text-text-primary uppercase tracking-wide">Ludothèque</h2>
					<p class="text-xs text-text-secondary mt-1">Jeux que vous avez déjà empruntés</p>
				</div>
				<a href="{{ path('app_ludotheque') }}" class="text-[10px] font-bold uppercase tracking-wider text-custom-orange hover:text-orange-400 transition-colors">
					Voir le catalogue public →
				</a>
			</div>

			<form method="get" action="{{ path('app_user_dashboard') }}#ludotheque" class="flex flex-wrap items-end gap-2 mb-4">
				<div class="relative flex-1 min-w-[160px]"
					 data-controller="search-autocomplete"
					 data-search-autocomplete-url-value="{{ path('app_ludotheque_suggest') }}">
					<label for="user-ludo-search" class="sr-only">Rechercher un jeu</label>
					<input type="text"
						   id="user-ludo-search"
						   name="q"
						   value="{{ search|default('') }}"
						   placeholder="Rechercher un jeu..."
						   autocomplete="off"
						   role="combobox"
						   aria-autocomplete="list"
						   aria-controls="user-ludo-suggestions"
						   data-search-autocomplete-target="input"
						   data-action="input->search-autocomplete#onInput keydown->search-autocomplete#onKeydown"
						   class="w-full rounded-lg border border-custom bg-custom-secondary px-3 py-2 text-sm text-text-primary placeholder-text-secondary/60 focus:border-custom-orange focus:outline-none focus:ring-1 focus:ring-custom-orange">
					<ul id="user-ludo-suggestions"
						data-search-autocomplete-target="list"
						data-action="click->search-autocomplete#select"
						role="listbox"
						hidden
						class="absolute z-30 mt-1 max-h-60 w-full overflow-auto rounded-lg border border-custom bg-custom-secondary shadow-lg py-1"></ul>
				</div>
				<button type="submit" class="rounded-lg bg-custom-orange px-4 py-2 text-[10px] font-extrabold uppercase tracking-widest text-gray-900 hover:bg-orange-600 transition-all">Rechercher</button>
				{% if search|default('') %}
					<a href="{{ path('app_user_dashboard') }}#ludotheque" class="text-[10px] font-bold uppercase tracking-wider text-text-secondary hover:text-custom-orange transition-colors py-2">Réinitialiser</a>
				{% endif %}
			</form>

			{% if boardGamesPagination|length > 0 %}
				<div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-2.5">
					{% for boardGame in boardGamesPagination %}
						{% set isOwn = boardGame.borrower and app.user and boardGame.borrower.id == app.user.id %}
						{% set pageParams = {} %}
						{% if boardGamesPagination.currentPageNumber > 1 %}{% set pageParams = pageParams|merge({ page: boardGamesPagination.currentPageNumber }) %}{% endif %}
						{% if search|default('') %}{% set pageParams = pageParams|merge({ q: search }) %}{% endif %}
						<div class="rounded-lg border border-custom bg-custom-secondary p-2.5 shadow-md glass-card flex flex-col gap-1.5">
							{% if boardGame.image %}
								<img src="{{ asset('images/board-games/' ~ boardGame.image) }}" alt="{{ boardGame.title }}" loading="lazy" width="200" height="112" class="w-full h-28 object-cover rounded-md border border-custom">
							{% endif %}
							<div class="min-w-0">
								<h3 class="text-xs font-bold text-text-primary truncate" title="{{ boardGame.title }}">{{ boardGame.title }}</h3>
								{% if boardGame.category %}
									<p class="text-[10px] text-text-secondary mt-0.5 truncate">{{ boardGame.category }}</p>
								{% endif %}
								<div class="flex flex-wrap gap-1.5 mt-1 text-[9px] text-text-secondary">
									{% if boardGame.maxPlayers %}<span>{{ boardGame.maxPlayers }}j max</span>{% endif %}
									{% if boardGame.durationMinutes %}<span>{{ boardGame.durationMinutes }} min</span>{% endif %}
									{% if boardGame.condition %}<span>{{ boardGame.condition }}</span>{% endif %}
								</div>
							</div>

							<div class="pt-1.5 border-t border-custom/50">
								{% if boardGame.status == 'available' %}
									{% if activeBoardGame %}
										<span class="inline-block text-[9px] font-bold uppercase tracking-wider text-text-secondary/60 px-2 py-1 rounded-md bg-white/5 border border-custom/30">
											Disponible
										</span>
										<p class="text-[9px] text-text-secondary/60 mt-1">Emprunt déjà en cours.</p>
									{% else %}
										<form method="post" action="{{ path('app_user_ludotheque_request', { id: boardGame.id }|merge(pageParams)) }}">
											<input type="hidden" name="_token" value="{{ csrf_token('request_loan' ~ boardGame.id) }}">
											<button type="submit" class="text-[9px] font-bold uppercase tracking-wider text-emerald-400 hover:text-emerald-300 px-2.5 py-1 rounded-md bg-emerald-400/10 border border-emerald-400/30 hover:bg-emerald-400/20 transition-all">
												Emprunter
											</button>
										</form>
									{% endif %}
								{% elseif boardGame.status == 'pending' %}
									{% if isOwn %}
										<div class="flex flex-wrap items-center gap-1.5">
											<span class="inline-block text-[9px] font-bold uppercase tracking-wider text-custom-orange px-2 py-1 rounded-md bg-custom-orange/10 border border-custom-orange/30">
												En attente
											</span>
											<form method="post" action="{{ path('app_user_ludotheque_cancel', { id: boardGame.id }|merge(pageParams)) }}" onsubmit="return confirm('Annuler votre demande d\'emprunt pour « {{ boardGame.title }} » ?');">
												<input type="hidden" name="_token" value="{{ csrf_token('cancel_loan' ~ boardGame.id) }}">
												<button type="submit" class="text-[9px] font-bold uppercase tracking-wider text-red-400 hover:text-red-300 px-2.5 py-1 rounded-md bg-red-400/10 border border-red-400/30 hover:bg-red-400/20 transition-all">
													Annuler
												</button>
											</form>
										</div>
									{% else %}
										<span class="inline-block text-[9px] font-bold uppercase tracking-wider text-text-secondary/60 px-2 py-1 rounded-md bg-white/5 border border-custom/30">
											Indisponible
										</span>
									{% endif %}
								{% elseif boardGame.status == 'loaned' %}
									{% if isOwn %}
										{% if boardGame.returnDueAt and boardGame.returnDueAt < date() %}
											<span class="inline-block text-[9px] font-bold uppercase tracking-wider text-white px-2 py-1 rounded-md bg-red-500 border border-red-500">
												En retard depuis le {{ boardGame.returnDueAt|date('d/m/Y') }}
											</span>
										{% else %}
											<span class="inline-block text-[9px] font-bold uppercase tracking-wider text-violet-400 px-2 py-1 rounded-md bg-violet-400/10 border border-violet-400/30">
												Emprunté{% if boardGame.returnDueAt %} jusqu'au {{ boardGame.returnDueAt|date('d/m/Y') }}{% endif %}
											</span>
										{% endif %}
									{% else %}
										<span class="inline-block text-[9px] font-bold uppercase tracking-wider text-text-secondary/60 px-2 py-1 rounded-md bg-white/5 border border-custom/30">
											Indisponible
										</span>
									{% endif %}
								{% endif %}
							</div>

							<div class="pt-1.5 border-t border-custom/50 flex flex-col gap-1.5">
								<div class="flex flex-col gap-0.5">
									<span class="text-[9px] font-bold uppercase tracking-wider text-text-secondary">Note</span>
									{{ include('components/_star_rating.html.twig', { rating: averageRatings[boardGame.id]|default(null), size: 'text-sm' }, with_context: false) }}
								</div>
								{% if canRate[boardGame.id] %}
									{{ include('components/_rate_form.html.twig', {
										ratePath: path('app_user_ludotheque_rate', { id: boardGame.id }|merge(pageParams)),
										csrfId: 'rate_game' ~ boardGame.id,
										myScore: myRatings[boardGame.id]|default(0),
									}, with_context: false) }}
								{% endif %}
							</div>
						</div>
					{% endfor %}
				</div>

				{% if boardGamesPagination.pageCount > 1 %}
					<div class="flex flex-col sm:flex-row items-center justify-between gap-4 mt-5">
						<p class="text-xs text-text-secondary">
							{{ boardGamesPagination.totalItemCount }} jeu{{ boardGamesPagination.totalItemCount > 1 ? 'x' : '' }}
							— page {{ boardGamesPagination.currentPageNumber }} / {{ boardGamesPagination.pageCount }}
						</p>
						<nav class="flex items-center gap-1" aria-label="Pagination de la ludothèque">
							{% if boardGamesPagination.currentPageNumber > 1 %}
								<a href="{{ path('app_user_dashboard', app.request.query.all|merge({page: boardGamesPagination.currentPageNumber - 1})) }}#ludotheque"
								   class="px-3 py-2 rounded-lg text-xs font-bold text-text-secondary hover:text-text-primary border border-custom hover:border-custom-orange transition-colors">&larr; Préc.</a>
							{% endif %}

							{% for page in 1..boardGamesPagination.pageCount %}
								{% if page == boardGamesPagination.currentPageNumber %}
									<span class="px-3 py-2 rounded-lg text-xs font-bold bg-custom-orange text-text-primary">{{ page }}</span>
								{% elseif page == 1 or page == boardGamesPagination.pageCount or (page >= boardGamesPagination.currentPageNumber - 2 and page <= boardGamesPagination.currentPageNumber + 2) %}
									<a href="{{ path('app_user_dashboard', app.request.query.all|merge({page: page})) }}#ludotheque"
									   class="px-3 py-2 rounded-lg text-xs font-bold text-text-secondary hover:text-text-primary border border-custom hover:border-custom-orange transition-colors">{{ page }}</a>
								{% elseif page == 2 or page == boardGamesPagination.pageCount - 1 %}
									<span class="px-1 text-text-secondary">…</span>
								{% endif %}
							{% endfor %}

							{% if boardGamesPagination.currentPageNumber < boardGamesPagination.pageCount %}
								<a href="{{ path('app_user_dashboard', app.request.query.all|merge({page: boardGamesPagination.currentPageNumber + 1})) }}#ludotheque"
								   class="px-3 py-2 rounded-lg text-xs font-bold text-text-secondary hover:text-text-primary border border-custom hover:border-custom-orange transition-colors">Suiv. &rarr;</a>
							{% endif %}
						</nav>
					</div>
				{% endif %}
			{% else %}
				<div class="rounded-2xl border border-custom bg-custom-secondary p-8 text-center glass-card">
					{% if search|default('') %}
						<p class="text-text-secondary text-sm mb-3">Aucun de vos emprunts ne correspond à « {{ search }} ».</p>
						<a href="{{ path('app_user_dashboard') }}#ludotheque" class="text-[10px] font-bold uppercase tracking-wider text-custom-orange hover:text-orange-400 transition-colors">Réinitialiser la recherche</a>
					{% else %}
						<p class="text-text-secondary text-sm mb-3">Vous n'avez pas encore emprunté de jeu.</p>
						<a href="{{ path('app_ludotheque') }}" class="text-[10px] font-bold uppercase tracking-wider text-custom-orange hover:text-orange-400 transition-colors">Parcourir le catalogue →</a>
					{% endif %}
				</div>
			{% endif %}
		</div>

		{# ── Zone à risque ── #}
		<div class="mt-12 pt-8 border-t border-custom/50">
			<h2 class="text-lg font-bold text-red-400 uppercase tracking-wide mb-6">Zone à risque</h2>

			{# Changer d'email #}
			<div class="rounded-xl border border-amber-500/30 bg-amber-500/5 p-5 mb-4">
				<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
					<div>
						<h3 class="text-sm font-bold text-text-primary mb-1">Changer d'adresse email</h3>
						<p class="text-xs text-text-secondary">Email actuel : <span class="text-amber-400 font-medium">{{ app.user.email }}</span></p>
					</div>
					<button type="button" data-toggle-hidden="change-email-form" class="cursor-pointer inline-flex items-center gap-2 rounded-lg border border-amber-500/30 bg-amber-500/10 px-4 py-2.5 text-[10px] font-extrabold uppercase tracking-widest text-amber-400 hover:bg-amber-500/20 transition-all self-start">
						<svg class="h-4 w-4" fill="none" stroke="currentColor" viewbox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
						Modifier
					</button>
				</div>
				<form id="change-email-form" method="post" action="{{ path('app_user_change_email') }}" class="hidden mt-4 flex flex-col gap-3">
					<input type="hidden" name="_token" value="{{ csrf_token('change_email') }}">
					<div>
						<label class="block text-[10px] font-bold uppercase tracking-wider text-text-secondary mb-1">Mot de passe actuel</label>
						<input type="password" name="current_password" required class="w-full rounded-lg border border-custom bg-custom-tertiary px-4 py-2.5 text-sm text-text-primary placeholder-text-secondary/60 focus:border-amber-500 focus:outline-none focus:ring-1 focus:ring-amber-500" placeholder="········" autocomplete="current-password">
					</div>
					<div>
						<label class="block text-[10px] font-bold uppercase tracking-wider text-text-secondary mb-1">Nouvelle adresse email</label>
						<input type="email" name="new_email" required placeholder="nouvelle@adresse.email" class="w-full rounded-lg border border-custom bg-custom-tertiary px-4 py-2.5 text-sm text-text-primary placeholder-text-secondary/60 focus:border-amber-500 focus:outline-none focus:ring-1 focus:ring-amber-500">
					</div>
					<button type="submit" class="rounded-lg bg-amber-500 px-5 py-2.5 text-[10px] font-extrabold uppercase tracking-widest text-white hover:bg-amber-600 transition-all self-start">
						Envoyer la confirmation
					</button>
				</form>
			</div>

			{# Changer de mot de passe #}
			<div class="rounded-xl border border-amber-500/30 bg-amber-500/5 p-5 mb-4">
				<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
					<div>
						<h3 class="text-sm font-bold text-text-primary mb-1">Changer de mot de passe</h3>
						<p class="text-xs text-text-secondary">Choisissez un nouveau mot de passe sécurisé.</p>
					</div>
					<button type="button" data-toggle-hidden="change-password-form" class="cursor-pointer inline-flex items-center gap-2 rounded-lg border border-amber-500/30 bg-amber-500/10 px-4 py-2.5 text-[10px] font-extrabold uppercase tracking-widest text-amber-400 hover:bg-amber-500/20 transition-all self-start">
						<svg class="h-4 w-4" fill="none" stroke="currentColor" viewbox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
						Modifier
					</button>
				</div>
				<form id="change-password-form" method="post" action="{{ path('app_user_change_password') }}" class="hidden mt-4 flex flex-col gap-3">
					<input type="hidden" name="_token" value="{{ csrf_token('change_password') }}">
					<div>
						<label class="block text-[10px] font-bold uppercase tracking-wider text-text-secondary mb-1">Mot de passe actuel</label>
						<div class="relative">
							<input type="password" id="dashboard_current_password" name="current_password" required class="w-full rounded-lg border border-custom bg-custom-tertiary px-4 py-2.5 pr-10 text-sm text-text-primary placeholder-text-secondary/60 focus:border-amber-500 focus:outline-none focus:ring-1 focus:ring-amber-500" placeholder="········" autocomplete="current-password">
							<button type="button" data-toggle-password="dashboard_current_password" class="absolute right-3 top-1/2 -translate-y-1/2 text-text-secondary hover:text-text-primary transition-colors" tabindex="-1" aria-label="Afficher le mot de passe">
								<svg class="h-4 w-4 eye-closed" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.878 9.878L6.5 6.5m3.378 3.378L6.5 6.5m0 0L3 3m3.5 3.5l10 10M17.5 17.5L21 21m-3.5-3.5l-10-10m13.043 4.51A9.953 9.953 0 0121 12c-1.275 4.057-5.065 7-9.543 7"/></svg>
								<svg class="h-4 w-4 eye-open hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
							</button>
						</div>
					</div>
					<div>
						<label class="block text-[10px] font-bold uppercase tracking-wider text-text-secondary mb-1">Nouveau mot de passe</label>
						<div class="relative">
							<input type="password" name="new_password" id="new_password" required minlength="12" class="w-full rounded-lg border border-custom bg-custom-tertiary px-4 py-2.5 pr-10 text-sm text-text-primary placeholder-text-secondary/60 focus:border-amber-500 focus:outline-none focus:ring-1 focus:ring-amber-500" placeholder="········" autocomplete="new-password">
							<button type="button" data-toggle-password="new_password" class="absolute right-3 top-1/2 -translate-y-1/2 text-text-secondary hover:text-text-primary transition-colors" tabindex="-1" aria-label="Afficher le mot de passe">
								<svg class="h-4 w-4 eye-closed" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.878 9.878L6.5 6.5m3.378 3.378L6.5 6.5m0 0L3 3m3.5 3.5l10 10M17.5 17.5L21 21m-3.5-3.5l-10-10m13.043 4.51A9.953 9.953 0 0121 12c-1.275 4.057-5.065 7-9.543 7"/></svg>
								<svg class="h-4 w-4 eye-open hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
							</button>
						</div>
					</div>
					<div>
						<label class="block text-[10px] font-bold uppercase tracking-wider text-text-secondary mb-1">Confirmer le nouveau mot de passe</label>
						<div class="relative">
							<input type="password" name="confirm_password" id="confirm_password" required minlength="12" class="w-full rounded-lg border border-custom bg-custom-tertiary px-4 py-2.5 pr-10 text-sm text-text-primary placeholder-text-secondary/60 focus:border-amber-500 focus:outline-none focus:ring-1 focus:ring-amber-500" placeholder="········" autocomplete="new-password">
							<button type="button" data-toggle-password="confirm_password" class="absolute right-3 top-1/2 -translate-y-1/2 text-text-secondary hover:text-text-primary transition-colors" tabindex="-1" aria-label="Afficher la confirmation du mot de passe">
								<svg class="h-4 w-4 eye-closed" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.878 9.878L6.5 6.5m3.378 3.378L6.5 6.5m0 0L3 3m3.5 3.5l10 10M17.5 17.5L21 21m-3.5-3.5l-10-10m13.043 4.51A9.953 9.953 0 0121 12c-1.275 4.057-5.065 7-9.543 7"/></svg>
								<svg class="h-4 w-4 eye-open hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
							</button>
						</div>
						<p id="password-mismatch" class="hidden text-xs text-red-400 mt-1">Les mots de passe ne correspondent pas.</p>
					</div>
					<button type="submit" class="self-start rounded-lg bg-amber-500 px-5 py-2.5 text-[10px] font-extrabold uppercase tracking-widest text-white hover:bg-amber-600 transition-all">
						Confirmer
					</button>
				</form>
			</div>

			{# Désabonnement newsletter #}
			<div class="rounded-xl border border-amber-500/30 bg-amber-500/5 p-5 mb-4">
				<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
					<div>
						<h3 class="text-sm font-bold text-text-primary mb-1">Newsletter</h3>
						{% if app.user.newsletterOptIn %}
							<p class="text-xs text-text-secondary">Vous êtes actuellement <span class="text-emerald-400 font-medium">abonné(e)</span> à la newsletter.</p>
						{% else %}
							<p class="text-xs text-text-secondary">Vous êtes actuellement <span class="text-text-secondary/60 font-medium">désabonné(e)</span> de la newsletter.</p>
						{% endif %}
					</div>
					{% if app.user.newsletterOptIn %}
						<button type="button" data-show="unsubscribe-newsletter-modal" class="cursor-pointer inline-flex items-center gap-2 rounded-lg border border-amber-500/30 bg-amber-500/10 px-4 py-2.5 text-[10px] font-extrabold uppercase tracking-widest text-amber-400 hover:bg-amber-500/20 transition-all self-start">
							<svg class="h-4 w-4" fill="none" stroke="currentColor" viewbox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"/></svg>
							Se désabonner
						</button>
					{% else %}
						<span class="inline-flex items-center gap-2 rounded-lg border border-custom/30 bg-white/5 px-4 py-2.5 text-[10px] font-extrabold uppercase tracking-widest text-text-secondary/50">
							Désabonné(e)
						</span>
					{% endif %}
				</div>
			</div>

			{# Supprimer le compte (utilisateurs simples uniquement) #}
			{% if not is_granted('ROLE_ADMIN') %}
				<div class="rounded-xl border border-red-500/30 bg-red-500/5 p-5">
					<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
						<div>
							<h3 class="text-sm font-bold text-text-primary mb-1">Supprimer mon compte</h3>
							<p class="text-xs text-text-secondary">Cette action est irréversible. Toutes vos données seront définitivement effacées.</p>
						</div>
						<button type="button" data-show="delete-account-modal" class="inline-flex items-center gap-2 rounded-lg border border-red-500/30 bg-red-500/10 px-4 py-2.5 text-[10px] font-extrabold uppercase tracking-widest text-red-400 hover:bg-red-500/20 transition-all self-start">
							<svg class="h-4 w-4" fill="none" stroke="currentColor" viewbox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
							Supprimer
						</button>
					</div>
				</div>
			{% endif %}
		</div>
	</div>

	{# ── Modale désabonnement newsletter ── #}
	{% if app.user.newsletterOptIn %}
		<div id="unsubscribe-newsletter-modal" class="hidden fixed inset-0 z-[200] flex items-center justify-center">
			<div class="absolute inset-0 bg-black/80 backdrop-blur-sm" data-hide="unsubscribe-newsletter-modal"></div>
			<div class="relative bg-custom-secondary border border-custom rounded-2xl shadow-2xl p-6 mx-4 max-w-md w-full">
				<h3 class="text-lg font-bold text-text-primary mb-2">Se désabonner de la newsletter</h3>
				<p class="text-sm text-text-secondary mb-6">Vous ne recevrez plus nos emails d'information et d'actualité. Vous pouvez vous réabonner à tout moment en contactant l'association.</p>
				<div class="flex items-center gap-3 justify-end">
					<button type="button" data-hide="unsubscribe-newsletter-modal" class="cursor-pointer rounded-lg border border-custom px-4 py-2.5 text-[10px] font-extrabold uppercase tracking-widest text-text-secondary hover:text-text-primary transition-all">
						Annuler
					</button>
					<form method="post" action="{{ path('app_user_newsletter') }}">
						<input type="hidden" name="_token" value="{{ csrf_token('newsletter_toggle') }}">
						<button type="submit" class="cursor-pointer rounded-lg bg-amber-500 px-4 py-2.5 text-[10px] font-extrabold uppercase tracking-widest text-white hover:bg-amber-600 transition-all">
							Confirmer le désabonnement
						</button>
					</form>
				</div>
			</div>
		</div>
	{% endif %}

	{# ── Modale de confirmation ── #}
	{% if not is_granted('ROLE_ADMIN') %}
		<div id="delete-account-modal" class="hidden fixed inset-0 z-[200] flex items-center justify-center">
			<div class="absolute inset-0 bg-black/80 backdrop-blur-sm" data-hide="delete-account-modal"></div>
			<div class="relative bg-custom-secondary border border-custom rounded-2xl shadow-2xl p-6 mx-4 max-w-md w-full">
				<h3 class="text-lg font-bold text-text-primary mb-2">Confirmer la suppression</h3>
				<p class="text-sm text-text-secondary mb-4">Êtes-vous sûr de vouloir supprimer définitivement votre compte <span class="text-custom-orange font-bold">{{ app.user.username }}</span> ? Cette action est irréversible.</p>
				<form method="post" action="{{ path('app_user_delete_account') }}" class="space-y-4">
					<div>
						<label for="delete-account-password" class="block text-xs font-bold uppercase tracking-wider text-text-primary mb-1">Confirmez avec votre mot de passe</label>
						<input type="password" id="delete-account-password" name="current_password" required autocomplete="current-password" class="w-full rounded-lg border border-custom bg-custom-tertiary px-4 py-3 text-text-primary focus:border-custom-orange focus:outline-none focus:ring-1 focus:ring-custom-orange">
					</div>
					<div class="flex items-center gap-3 justify-end">
					<button type="button" data-hide="delete-account-modal" class="rounded-lg border border-custom px-4 py-2.5 text-[10px] font-extrabold uppercase tracking-widest text-text-secondary hover:text-text-primary transition-all">
						Annuler
					</button>
						<input type="hidden" name="_token" value="{{ csrf_token('delete_my_account') }}">
						<button type="submit" class="rounded-lg bg-red-500 px-4 py-2.5 text-[10px] font-extrabold uppercase tracking-widest text-white hover:bg-red-600 transition-all">
							Supprimer définitivement
						</button>
					</div>
				</form>
			</div>
		</div>
	{% endif %}
{% endblock %}
