{% extends 'admin/layout.html.twig' %}

{% block title %}Nouvel article - La Boîte à Chimère{% endblock %}

{% block admin_body %}
	<link href="/vendor/quill/quill.snow.css" rel="stylesheet">
	<style>
		.ql-toolbar {
			background-color: rgba(255, 255, 255, 0.05);
			border-color: rgba(255, 255, 255, 0.1) !important;
			border-top-left-radius: 8px;
			border-top-right-radius: 8px;
		}
		.ql-container {
			border-color: rgba(255, 255, 255, 0.1) !important;
			border-bottom-left-radius: 8px;
			border-bottom-right-radius: 8px;
			font-family: inherit;
			font-size: 14px;
			background-color: rgba(255, 255, 255, 0.02);
			color: #fff;
		}
		.ql-editor {
			min-height: 400px;
		}
		.ql-snow .ql-stroke {
			stroke: #a3a3a3;
		}
		.ql-snow .ql-fill {
			fill: #a3a3a3;
		}
		.ql-snow .ql-picker {
			color: #a3a3a3;
		}
		.ql-snow .ql-picker-options {
			background-color: #1a1a1a !important;
			border-color: rgba(255, 255, 255, 0.1) !important;
		}
	</style>

	<div class="min-h-screen mx-auto max-w-[1240px] px-4 sm:px-8 py-8" data-controller="article-form">
		<a href="{{ path('app_admin_article_index') }}" class="inline-flex items-center gap-2 text-[10px] font-bold uppercase tracking-wider text-text-secondary hover:text-custom-orange transition-colors mb-6">
			<svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
			Retour aux articles
		</a>

		<div class="flex flex-col xl:flex-row gap-8 items-start">
			<div class="w-full xl:w-7/12 rounded-2xl border border-custom bg-custom-secondary p-6 lg:p-8 shadow-2xl glass-card">
				<h1 class="text-xl font-bold text-text-primary uppercase tracking-wide mb-6">Nouvel article</h1>
				{{ include('admin/article/_form.html.twig', { form: form, button_label: 'Créer l\'article', form_action: path('app_admin_article_new') }) }}
			</div>

			<div class="w-full xl:w-5/12 xl:sticky xl:top-8 rounded-2xl border border-custom bg-custom-secondary p-6 shadow-2xl glass-card">
				<div class="flex items-center justify-between mb-6 border-b border-custom pb-4">
					<h2 class="text-xs font-bold text-text-primary uppercase tracking-wider">Aperçu en direct</h2>
					<div class="flex bg-custom-tertiary rounded-lg p-0.5 border border-custom">
						<button type="button" data-article-form-target="previewCardBtn" data-action="click->article-form#showCardPreview" class="px-3 py-1.5 rounded-md text-[9px] font-bold uppercase tracking-wider bg-custom-orange text-gray-900 shadow transition-all">Format Carte</button>
						<button type="button" data-article-form-target="previewDetailBtn" data-action="click->article-form#showDetailPreview" class="px-3 py-1.5 rounded-md text-[9px] font-bold uppercase tracking-wider text-text-secondary hover:text-text-primary transition-all">Page de l'article</button>
					</div>
				</div>

				<div data-article-form-target="cardSection" class="space-y-4">
					<p class="text-[9px] text-text-secondary uppercase tracking-widest text-center mb-2">Rendu sur la page d'accueil</p>
					<div class="max-w-[360px] mx-auto">
						<div class="group relative overflow-hidden rounded-xl bg-custom-tertiary shadow-lg block card-premium aspect-[1.8/1] min-h-[220px] border border-custom">
							<img data-article-form-target="cardImg" src="" alt="Illustration de l'article" class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 hidden">
							<div data-article-form-target="cardImgPlaceholder" class="absolute inset-0 flex items-center justify-center bg-custom-secondary border-dashed border-2 border-custom text-text-secondary text-xs">
								Aucune image
							</div>
							<div class="absolute inset-0 image-overlay"></div>
							<span data-article-form-target="cardTag" class="absolute right-3 top-3 bg-custom-orange px-2 py-1 rounded text-[9px] font-bold text-gray-900 uppercase tracking-widest shadow-lg">TAG</span>
							<div class="absolute bottom-4 left-4 right-4 z-10">
								<h3 data-article-form-target="cardTitle" class="text-sm font-bold leading-tight text-text-primary uppercase">Titre de l'article</h3>
							</div>
						</div>
					</div>
				</div>

				<div data-article-form-target="detailSection" class="hidden space-y-4">
					<p class="text-[9px] text-text-secondary uppercase tracking-widest text-center mb-2">Rendu sur la page de l'article</p>
					<div class="w-full rounded-xl border border-custom bg-custom-tertiary p-4 shadow-xl relative overflow-hidden max-h-[500px] overflow-y-auto">
						<div class="flex items-center gap-3 mb-4">
							<span data-article-form-target="detailTag" class="inline-block rounded-md bg-custom-orange/10 px-2.5 py-1 text-[9px] font-bold uppercase tracking-wider text-custom-orange">TAG</span>
						</div>

						<div data-article-form-target="detailImgContainer" class="mb-4 overflow-hidden rounded-lg border border-custom max-w-xl mx-auto aspect-video relative shadow-lg hidden">
							<img data-article-form-target="detailImg" src="" alt="Illustration de l'article" class="h-full w-full object-cover">
						</div>

						<h3 data-article-form-target="detailTitle" class="text-base font-bold text-text-primary mb-3 uppercase">Titre de l'article</h3>

						<div data-article-form-target="previewContent" class="prose prose-invert max-w-none text-text-secondary text-xs leading-relaxed space-y-3">
							<p class="italic text-text-secondary/50">Rédigez votre texte pour voir l'aperçu...</p>
						</div>

						<div data-article-form-target="galleryContainer" class="mt-6 pt-4 border-t border-custom hidden">
							<span class="block text-[10px] font-bold uppercase tracking-wider text-text-primary mb-2">Galerie d'images</span>
							<div data-article-form-target="galleryGrid" class="grid grid-cols-3 gap-2">
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
{% endblock %}
