{{ form_start(form, { action: form_action, attr: { class: 'space-y-4', 'data-turbo': 'false', enctype: 'multipart/form-data' } }) }}
	<div>
		{{ form_label(form.title) }}
		{{ form_widget(form.title) }}
		<div class="text-amber-400 text-xs mt-1">{{ form_errors(form.title) }}</div>
	</div>
	<div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
		<div>
			{{ form_label(form.category) }}
			{{ form_widget(form.category) }}
			<div class="text-amber-400 text-xs mt-1">{{ form_errors(form.category) }}</div>
		</div>
		<div>
			{{ form_label(form.condition) }}
			{{ form_widget(form.condition) }}
			<div class="text-amber-400 text-xs mt-1">{{ form_errors(form.condition) }}</div>
		</div>
	</div>
	<div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
		<div>
			{{ form_label(form.maxPlayers) }}
			{{ form_widget(form.maxPlayers) }}
			<div class="text-amber-400 text-xs mt-1">{{ form_errors(form.maxPlayers) }}</div>
		</div>
		<div>
			{{ form_label(form.durationMinutes) }}
			{{ form_widget(form.durationMinutes) }}
			<div class="text-amber-400 text-xs mt-1">{{ form_errors(form.durationMinutes) }}</div>
		</div>
	</div>
	<div>
		{{ form_label(form.notes) }}
		{{ form_widget(form.notes) }}
		<div class="text-amber-400 text-xs mt-1">{{ form_errors(form.notes) }}</div>
	</div>
	<div>
		{{ form_label(form.imageFile) }}
		{{ form_widget(form.imageFile) }}
		<p class="text-[10px] text-text-secondary mt-1">Formats acceptés : PNG ou JPEG — taille max. 250 Ko.</p>
		<div class="text-amber-400 text-xs mt-1">{{ form_errors(form.imageFile) }}</div>
		{% set boardGame = form.vars.value %}
		{% if boardGame and boardGame.image %}
			<div class="mt-3 rounded-lg border border-custom bg-custom-tertiary p-3 inline-block">
				<p class="text-[10px] font-bold uppercase tracking-wider text-text-secondary mb-2">Image actuelle</p>
				<img src="{{ asset('images/board-games/' ~ boardGame.image) }}" alt="{{ boardGame.title }}" class="h-28 w-28 object-cover rounded-md border border-custom">
			</div>
		{% endif %}
	</div>
	<div class="flex flex-wrap gap-3 pt-2">
		<button type="submit" class="cursor-pointer rounded-lg bg-custom-orange py-3 px-6 text-sm font-extrabold uppercase tracking-widest text-text-primary hover:bg-orange-600 transition-all shadow-lg shadow-custom-orange/20">
			{{ button_label|default('Enregistrer') }}
		</button>
		<a href="{{ path('app_admin_ludotheque_index') }}" class="rounded-lg border border-custom bg-custom-secondary py-3 px-6 text-sm font-bold uppercase tracking-wider text-text-secondary hover:text-text-primary hover:border-custom-orange transition-all">
			Annuler
		</a>
	</div>
{{ form_end(form) }}
