{% extends 'admin/layout.html.twig' %}

{% block title %}Gestion de la ludothèque - La Boîte à Chimère{% endblock %}

{% block admin_body %}
	<div class="min-h-screen mx-auto max-w-[1240px] px-4 sm:px-8 py-8">
		<a href="{{ path('admin') }}" class="inline-flex items-center gap-2 text-[10px] font-bold uppercase tracking-wider text-text-secondary hover:text-custom-orange transition-colors mb-6">
			<svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
			Retour au dashboard
		</a>

		<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-8">
			<h1 class="text-2xl font-bold text-text-primary uppercase tracking-wide">Gestion de la ludothèque</h1>
			<a href="{{ path('app_admin_ludotheque_new') }}" class="inline-flex items-center gap-2 rounded-lg bg-custom-orange py-3 px-5 text-sm font-extrabold uppercase tracking-widest text-text-primary hover:bg-orange-600 transition-all shadow-lg shadow-custom-orange/20">
				<svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
				Nouveau jeu
			</a>
		</div>

		{% if pagination.totalItemCount > 0 %}
			{# Vue mobile : cartes empilées #}
			<div class="lg:hidden space-y-3">
				{% for boardGame in pagination %}
					<div class="rounded-xl border border-custom bg-custom-secondary p-4 shadow-lg glass-card {{ boardGame.status == 'pending' ? 'border-custom-orange/30 bg-custom-orange/5' : '' }}">
						<div class="flex items-start justify-between gap-3 mb-2">
							<h3 class="font-medium text-text-primary text-sm">{{ boardGame.title }}{% if averageRatings[boardGame.id] is not null %} <span class="text-amber-400 font-bold">★ {{ averageRatings[boardGame.id]|number_format(1) }}</span>{% endif %}</h3>
							{% if boardGame.status == 'pending' %}
								<span class="bg-custom-orange text-white text-[9px] font-bold uppercase tracking-wider px-2 py-0.5 rounded-full shrink-0">En attente</span>
							{% elseif boardGame.status == 'loaned' and boardGame.returnDueAt and boardGame.returnDueAt < date() %}
								<span class="bg-red-500 text-white text-[9px] font-bold uppercase tracking-wider px-2 py-0.5 rounded-full shrink-0">En retard depuis le {{ boardGame.returnDueAt|date('d/m/Y') }}</span>
							{% elseif boardGame.status == 'loaned' %}
								<span class="bg-violet-500 text-white text-[9px] font-bold uppercase tracking-wider px-2 py-0.5 rounded-full shrink-0">Emprunté</span>
							{% else %}
								<span class="bg-emerald-500/20 text-emerald-400 text-[9px] font-bold uppercase tracking-wider px-2 py-0.5 rounded-full shrink-0">Disponible</span>
							{% endif %}
						</div>
						<div class="flex flex-col gap-1 text-xs text-text-secondary mb-3">
							{% if boardGame.category %}<span>{{ boardGame.category }}</span>{% endif %}
							{% if boardGame.borrower %}
								<span class="flex items-center gap-1.5">
									<svg class="h-3 w-3 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
									{{ boardGame.borrower.username }} ({{ boardGame.borrower.email }})
								</span>
							{% endif %}
							{% if boardGame.status == 'loaned' and boardGame.returnDueAt %}
								<span>Retour prévu le {{ boardGame.returnDueAt|date('d/m/Y') }}</span>
							{% endif %}
						</div>
						<div class="flex flex-wrap items-center gap-3 pt-2 border-t border-custom/50">
							{% if boardGame.status == 'pending' %}
								<form method="post" action="{{ path('app_admin_ludotheque_approve', { id: boardGame.id }) }}" class="flex items-center gap-2">
									<input type="hidden" name="_token" value="{{ csrf_token('approve' ~ boardGame.id) }}">
									<input type="date" name="returnDueAt" required class="rounded-lg border border-custom bg-custom-tertiary px-2 py-1 text-xs text-text-primary focus:border-custom-orange focus:outline-none">
									<button type="submit" class="text-[10px] font-bold uppercase tracking-wider text-green-400 hover:text-green-300 transition-colors">Valider</button>
								</form>
								<form method="post" action="{{ path('app_admin_ludotheque_reject', { id: boardGame.id }) }}" class="contents" onsubmit="return confirm('Rejeter cette demande d\'emprunt ?')">
									<input type="hidden" name="_token" value="{{ csrf_token('reject' ~ boardGame.id) }}">
									<button type="submit" class="text-[10px] font-bold uppercase tracking-wider text-red-400 hover:text-red-300 transition-colors">Rejeter</button>
								</form>
							{% elseif boardGame.status == 'loaned' %}
								<form method="post" action="{{ path('app_admin_ludotheque_return', { id: boardGame.id }) }}" class="contents" onsubmit="return confirm('Marquer ce jeu comme retourné ?')">
									<input type="hidden" name="_token" value="{{ csrf_token('return' ~ boardGame.id) }}">
									<button type="submit" class="text-[10px] font-bold uppercase tracking-wider text-custom-orange hover:text-orange-400 transition-colors">Marquer retourné</button>
								</form>
							{% else %}
								<a href="{{ path('app_admin_ludotheque_edit', { id: boardGame.id }) }}" class="text-[10px] font-bold uppercase tracking-wider text-custom-orange hover:text-orange-400 transition-colors">Modifier</a>
								<form method="post" action="{{ path('app_admin_ludotheque_archive', { id: boardGame.id }) }}" class="contents" onsubmit="return confirm('Archiver ce jeu ?')">
									<input type="hidden" name="_token" value="{{ csrf_token('archive' ~ boardGame.id) }}">
									<button type="submit" class="text-[10px] font-bold uppercase tracking-wider text-red-400 hover:text-red-300 transition-colors">Archiver</button>
								</form>
							{% endif %}
						</div>
					</div>
				{% endfor %}
			</div>

			{# Vue desktop : tableau #}
			<div class="hidden lg:block rounded-2xl border border-custom bg-custom-secondary overflow-hidden shadow-xl glass-card">
				<div class="overflow-x-auto">
					<table class="w-full text-left">
						<thead class="bg-custom-tertiary/50 border-b border-custom">
							<tr>
								<th class="px-4 py-3 text-[10px] font-bold uppercase tracking-wider text-text-secondary">Titre</th>
								<th class="px-4 py-3 text-[10px] font-bold uppercase tracking-wider text-text-secondary">Catégorie</th>
								<th class="px-4 py-3 text-[10px] font-bold uppercase tracking-wider text-text-secondary">Statut</th>
								<th class="px-4 py-3 text-[10px] font-bold uppercase tracking-wider text-text-secondary">Emprunteur</th>
								<th class="px-4 py-3 text-[10px] font-bold uppercase tracking-wider text-text-secondary text-right">Actions</th>
							</tr>
						</thead>
						<tbody>
							{% for boardGame in pagination %}
								<tr class="border-b border-custom/50 hover:bg-white/5 transition-colors {{ boardGame.status == 'pending' ? 'bg-custom-orange/5' : '' }}">
									<td class="px-4 py-3 font-medium text-text-primary">{{ boardGame.title }}{% if averageRatings[boardGame.id] is not null %} <span class="text-amber-400 font-bold text-xs">★ {{ averageRatings[boardGame.id]|number_format(1) }}</span>{% endif %}</td>
									<td class="px-4 py-3 text-sm text-text-secondary">{{ boardGame.category|default('—') }}</td>
									<td class="px-4 py-3">
										{% if boardGame.status == 'pending' %}
											<span class="bg-custom-orange text-white text-[9px] font-bold uppercase tracking-wider px-2 py-0.5 rounded-full">En attente</span>
										{% elseif boardGame.status == 'loaned' and boardGame.returnDueAt and boardGame.returnDueAt < date() %}
											<span class="bg-red-500 text-white text-[9px] font-bold uppercase tracking-wider px-2 py-0.5 rounded-full">En retard depuis le {{ boardGame.returnDueAt|date('d/m/Y') }}</span>
										{% elseif boardGame.status == 'loaned' %}
											<span class="bg-violet-500 text-white text-[9px] font-bold uppercase tracking-wider px-2 py-0.5 rounded-full">Emprunté{% if boardGame.returnDueAt %} jusqu'au {{ boardGame.returnDueAt|date('d/m/Y') }}{% endif %}</span>
										{% else %}
											<span class="bg-emerald-500/20 text-emerald-400 text-[9px] font-bold uppercase tracking-wider px-2 py-0.5 rounded-full">Disponible</span>
										{% endif %}
									</td>
									<td class="px-4 py-3 text-sm text-text-secondary">
										{% if boardGame.borrower %}
											<span class="text-text-secondary">{{ boardGame.borrower.username }} ({{ boardGame.borrower.email }})</span>
										{% else %}
											<span class="text-text-secondary/40">—</span>
										{% endif %}
									</td>
									<td class="px-4 py-3 text-right whitespace-nowrap">
										{% if boardGame.status == 'pending' %}
											<form method="post" action="{{ path('app_admin_ludotheque_approve', { id: boardGame.id }) }}" class="inline-flex items-center gap-2 mr-3">
												<input type="hidden" name="_token" value="{{ csrf_token('approve' ~ boardGame.id) }}">
												<input type="date" name="returnDueAt" required class="rounded-lg border border-custom bg-custom-tertiary px-2 py-1 text-xs text-text-primary focus:border-custom-orange focus:outline-none">
												<button type="submit" class="text-[10px] font-bold uppercase tracking-wider text-green-400 hover:text-green-300 transition-colors">Valider</button>
											</form>
											<form method="post" action="{{ path('app_admin_ludotheque_reject', { id: boardGame.id }) }}" class="inline" onsubmit="return confirm('Rejeter cette demande d\'emprunt ?')">
												<input type="hidden" name="_token" value="{{ csrf_token('reject' ~ boardGame.id) }}">
												<button type="submit" class="text-[10px] font-bold uppercase tracking-wider text-red-400 hover:text-red-300 transition-colors">Rejeter</button>
											</form>
										{% elseif boardGame.status == 'loaned' %}
											<form method="post" action="{{ path('app_admin_ludotheque_return', { id: boardGame.id }) }}" class="inline" onsubmit="return confirm('Marquer ce jeu comme retourné ?')">
												<input type="hidden" name="_token" value="{{ csrf_token('return' ~ boardGame.id) }}">
												<button type="submit" class="text-[10px] font-bold uppercase tracking-wider text-custom-orange hover:text-orange-400 transition-colors">Marquer retourné</button>
											</form>
										{% else %}
											<a href="{{ path('app_admin_ludotheque_edit', { id: boardGame.id }) }}" class="inline-flex items-center gap-1 text-[10px] font-bold uppercase tracking-wider text-custom-orange hover:text-orange-400 transition-colors mr-3">Modifier</a>
											<form method="post" action="{{ path('app_admin_ludotheque_archive', { id: boardGame.id }) }}" class="inline" onsubmit="return confirm('Archiver ce jeu ?')">
												<input type="hidden" name="_token" value="{{ csrf_token('archive' ~ boardGame.id) }}">
												<button type="submit" class="text-[10px] font-bold uppercase tracking-wider text-red-400 hover:text-red-300 transition-colors">Archiver</button>
											</form>
										{% endif %}
									</td>
								</tr>
							{% endfor %}
						</tbody>
					</table>
				</div>
			</div>

			{# Pagination #}
			{% if pagination.pageCount > 1 %}
				<div class="flex flex-col sm:flex-row items-center justify-between gap-4 mt-6">
					<p class="text-xs text-text-secondary">
						{{ pagination.totalItemCount }} jeu{{ pagination.totalItemCount > 1 ? 'x' : '' }}
						— page {{ pagination.currentPageNumber }} / {{ pagination.pageCount }}
					</p>
					<nav class="flex items-center gap-1">
						{% if pagination.currentPageNumber > 1 %}
							<a href="{{ path('app_admin_ludotheque_index', app.request.query.all|merge({page: pagination.currentPageNumber - 1})) }}"
							   class="px-3 py-2 rounded-lg text-xs font-bold text-text-secondary hover:text-text-primary border border-custom hover:border-custom-orange transition-colors">&larr; Préc.</a>
						{% endif %}

						{% for page in 1..pagination.pageCount %}
							{% if page == pagination.currentPageNumber %}
								<span class="px-3 py-2 rounded-lg text-xs font-bold bg-custom-orange text-text-primary">{{ page }}</span>
							{% elseif page == 1 or page == pagination.pageCount or (page >= pagination.currentPageNumber - 2 and page <= pagination.currentPageNumber + 2) %}
								<a href="{{ path('app_admin_ludotheque_index', app.request.query.all|merge({page: page})) }}"
								   class="px-3 py-2 rounded-lg text-xs font-bold text-text-secondary hover:text-text-primary border border-custom hover:border-custom-orange transition-colors">{{ page }}</a>
							{% elseif page == 2 or page == pagination.pageCount - 1 %}
								<span class="px-1 text-text-secondary">…</span>
							{% endif %}
						{% endfor %}

						{% if pagination.currentPageNumber < pagination.pageCount %}
							<a href="{{ path('app_admin_ludotheque_index', app.request.query.all|merge({page: pagination.currentPageNumber + 1})) }}"
							   class="px-3 py-2 rounded-lg text-xs font-bold text-text-secondary hover:text-text-primary border border-custom hover:border-custom-orange transition-colors">Suiv. &rarr;</a>
						{% endif %}
					</nav>
				</div>
			{% endif %}

		{% else %}
			<div class="rounded-2xl border border-custom bg-custom-secondary overflow-hidden shadow-xl glass-card px-6 py-12 text-center">
				<p class="text-text-secondary mb-4">Aucun jeu dans la ludothèque pour le moment.</p>
				<a href="{{ path('app_admin_ludotheque_new') }}" class="inline-flex items-center gap-2 rounded-lg bg-custom-orange py-2.5 px-4 text-xs font-extrabold uppercase tracking-widest text-text-primary hover:bg-orange-600 transition-all">
					<svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
					Ajouter un jeu
				</a>
			</div>
		{% endif %}
	</div>
{% endblock %}
