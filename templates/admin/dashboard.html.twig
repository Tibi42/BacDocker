{% extends 'admin/layout.html.twig' %}

{% block title %}Dashboard - La Boîte à Chimère{% endblock %}

{% block admin_body %}
<div class="mx-auto max-w-[1240px] px-4 sm:px-8 py-8">

    <div class="mb-8">
        <h1 class="text-2xl font-bold text-text-primary uppercase tracking-wide">Tableau de bord</h1>
        <p class="text-sm text-text-secondary mt-1">La Boîte à Chimère — Administration</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-4">

        {# En attente d'approbation #}
        <a href="{{ path('app_activity_index', { status: 'pending' }) }}"
           class="flex flex-col gap-3 p-5 rounded-2xl border border-custom bg-custom-secondary shadow-lg glass-card hover:border-custom-orange transition-colors text-decoration-none">
            <div class="flex items-center gap-3">
                <span class="text-3xl">⏳</span>
                <div>
                    <div class="font-bold text-text-primary">En attente</div>
                    <div class="text-xs text-text-secondary">Événements à approuver</div>
                </div>
            </div>
            <div class="flex justify-between items-end mt-auto">
                <span class="text-4xl font-extrabold text-text-primary" style="line-height:1.1">{{ pendingActivitiesCount|default(0) }}</span>
                <span class="text-[10px] font-bold uppercase tracking-widest px-2.5 py-1 rounded-lg bg-custom-orange text-text-primary">Voir →</span>
            </div>
        </a>

        {# Total membres inscrits (actifs uniquement) #}
        <div class="flex flex-col gap-3 p-5 rounded-2xl border border-custom bg-custom-secondary shadow-lg glass-card hover:border-custom-orange transition-colors">
            <button type="button" id="members-stats-open" class="flex items-center gap-3 text-left w-full cursor-pointer">
                <span class="text-3xl">👥</span>
                <div>
                    <div class="font-bold text-text-primary">Membres inscrits</div>
                    <div class="text-xs text-text-secondary">Actifs / suspendus</div>
                </div>
            </button>
            <div class="flex justify-between items-end mt-auto">
                <button type="button" id="members-stats-open-count" class="flex items-baseline gap-2 cursor-pointer text-left">
                    <span class="text-4xl font-extrabold text-emerald-400" style="line-height:1.1">{{ totalUsers|default(0) }}</span>
                    <span class="text-2xl font-extrabold text-text-secondary" style="line-height:1.1">/</span>
                    <span class="text-4xl font-extrabold text-red-400" style="line-height:1.1">{{ inactiveUsers|default(0) }}</span>
                </button>
                <a href="{{ path('app_admin_user_index') }}"
                   class="text-[10px] font-bold uppercase tracking-widest px-2.5 py-1 rounded-lg bg-custom-orange text-gray-900 hover:bg-orange-600 transition-colors">Gérer →</a>
            </div>
        </div>

        {# Dernières inscriptions #}
        <div class="flex flex-col gap-3 p-5 rounded-2xl border border-custom bg-custom-secondary shadow-lg glass-card">
            <div class="flex items-center gap-3">
                <span class="text-3xl">⏱️</span>
                <div>
                    <div class="font-bold text-text-primary">Derniers inscrits à une activité</div>
                    <div class="text-xs text-text-secondary">10 dernières inscriptions</div>
                </div>
            </div>
            {% if latestInscriptions|length > 0 %}
                <div class="flex flex-col gap-2 mt-auto">
                    {% for inscription in latestInscriptions %}
                        <div class="flex justify-between items-start gap-3">
                            <div class="min-w-0">
                                <div class="text-sm font-semibold text-text-primary truncate">
                                    {{ inscription.participantName|default(inscription.participantEmail) }}
                                </div>
                                <div class="text-xs text-text-secondary truncate">{{ inscription.activity.title|default('—') }}</div>
                            </div>
                            <div class="text-xs text-text-secondary whitespace-nowrap">{{ inscription.createdAt|date('d/m H:i') }}</div>
                        </div>
                    {% endfor %}
                </div>
            {% else %}
                <div class="mt-auto text-xs text-text-secondary">Aucune inscription pour le moment.</div>
            {% endif %}
        </div>

        {# Top proposants #}
        <div class="flex flex-col gap-3 p-5 rounded-2xl border border-custom bg-custom-secondary shadow-lg glass-card">
            <div class="flex items-center gap-3">
                <span class="text-3xl">🏆</span>
                <div>
                    <div class="font-bold text-text-primary">Top proposants</div>
                    <div class="text-xs text-text-secondary">Mois en cours</div>
                </div>
            </div>
            {% if topProposers|length > 0 %}
                <div class="flex flex-col gap-2 mt-auto">
                    {% for proposer in topProposers %}
                        <div class="flex justify-between items-center gap-3">
                            <span class="font-semibold text-sm text-text-primary truncate">
                                {{ proposer.username|default(proposer.email)|default('—') }}
                            </span>
                            <span class="text-[10px] font-bold uppercase tracking-widest px-2 py-0.5 rounded bg-custom-orange text-text-primary shrink-0">{{ proposer.activityCount }}</span>
                        </div>
                    {% endfor %}
                </div>
            {% else %}
                <div class="mt-auto text-xs text-text-secondary">Aucune activité proposée sur la période.</div>
            {% endif %}
        </div>

        {# Derniers membres #}
        <div class="flex flex-col gap-3 p-5 rounded-2xl border border-custom bg-custom-secondary shadow-lg glass-card">
            <div class="flex items-center gap-3">
                <span class="text-3xl">👥</span>
                <div>
                    <div class="font-bold text-text-primary">Nouveaux membres</div>
                    <div class="text-xs text-text-secondary">Derniers inscrits</div>
                </div>
            </div>
            {% if latestUsers|length > 0 %}
                <div class="flex flex-col gap-2 mt-auto">
                    {% for user in latestUsers %}
                        <div class="flex justify-between items-center gap-3">
                            <div class="min-w-0">
                                <div class="text-sm font-semibold text-text-primary truncate">{{ user.username }}</div>
                                <div class="text-xs text-text-secondary truncate">{{ user.email }}</div>
                            </div>
                            {% if 'ROLE_ADMIN' in user.roles or 'ROLE_SUPER_ADMIN' in user.roles %}
                                <span class="text-[9px] font-bold uppercase tracking-widest px-2 py-0.5 rounded bg-custom-orange/20 text-custom-orange shrink-0">Admin</span>
                            {% endif %}
                        </div>
                    {% endfor %}
                </div>
            {% else %}
                <div class="mt-auto text-xs text-text-secondary">Aucun membre pour le moment.</div>
            {% endif %}
        </div>

        {# Activités — visible uniquement sur mobile (la sidebar prend le relais sur desktop) #}
        <a href="{{ path('app_activity_index') }}"
           class="flex flex-col gap-3 p-5 rounded-2xl border border-custom bg-custom-secondary shadow-lg glass-card hover:border-custom-orange transition-colors lg:hidden">
            <div class="flex items-center gap-3">
                <span class="text-3xl">🎲</span>
                <div>
                    <div class="font-bold text-text-primary">Activités</div>
                    <div class="text-xs text-text-secondary">Gestion du calendrier</div>
                </div>
            </div>
            <div class="mt-auto">
                <span class="text-[10px] font-bold uppercase tracking-widest px-2.5 py-1 rounded-lg bg-custom-orange text-text-primary">Gérer →</span>
            </div>
        </a>

        {# Carousel — visible uniquement sur mobile #}
        <a href="{{ path('app_admin_carousel_index') }}"
           class="flex flex-col gap-3 p-5 rounded-2xl border border-custom bg-custom-secondary shadow-lg glass-card hover:border-custom-orange transition-colors lg:hidden">
            <div class="flex items-center gap-3">
                <span class="text-3xl">🖼️</span>
                <div>
                    <div class="font-bold text-text-primary">Carrousel</div>
                    <div class="text-xs text-text-secondary">Slides de la page d'accueil</div>
                </div>
            </div>
            <div class="mt-auto">
                <span class="text-[10px] font-bold uppercase tracking-widest px-2.5 py-1 rounded-lg bg-custom-orange text-text-primary">Gérer →</span>
            </div>
        </a>

        {# Ludothèque — visible uniquement sur mobile #}
        <a href="{{ path('app_admin_ludotheque_index') }}"
           class="flex flex-col gap-3 p-5 rounded-2xl border border-custom bg-custom-secondary shadow-lg glass-card hover:border-custom-orange transition-colors lg:hidden">
            <div class="flex items-center gap-3">
                <span class="text-3xl">📚</span>
                <div>
                    <div class="font-bold text-text-primary">Ludothèque</div>
                    <div class="text-xs text-text-secondary">Gestion des jeux</div>
                </div>
            </div>
            <div class="mt-auto">
                <span class="text-[10px] font-bold uppercase tracking-widest px-2.5 py-1 rounded-lg bg-custom-orange text-text-primary">Gérer →</span>
            </div>
        </a>

        {# Newsletter #}
        <a href="{{ path('app_admin_newsletter_index') }}"
           class="flex flex-col gap-3 p-5 rounded-2xl border border-custom bg-custom-secondary shadow-lg glass-card hover:border-custom-orange transition-colors">
            <div class="flex items-center gap-3">
                <span class="text-3xl">📧</span>
                <div>
                    <div class="font-bold text-text-primary">Newsletter</div>
                    <div class="text-xs text-text-secondary">Gestion des abonnés</div>
                </div>
            </div>
            <div class="flex justify-between items-end mt-auto">
                <div class="flex items-baseline gap-2">
                    <span class="text-2xl font-extrabold text-emerald-400">{{ newsletterConfirmed|default(0) }}</span>
                    <span class="text-xs text-text-secondary">confirmés</span>
                    {% if newsletterPending|default(0) > 0 %}
                        <span class="text-lg font-bold text-amber-400 ml-2">{{ newsletterPending }}</span>
                        <span class="text-xs text-text-secondary">en attente</span>
                    {% endif %}
                </div>
                <span class="text-[10px] font-bold uppercase tracking-widest px-2.5 py-1 rounded-lg bg-custom-orange text-text-primary">Gérer →</span>
            </div>
        </a>

        {# Site public #}
        <a href="{{ path('app_home') }}"
           class="flex flex-col gap-3 p-5 rounded-2xl border border-custom bg-custom-secondary shadow-lg glass-card hover:border-white/20 transition-colors">
            <div class="flex items-center gap-3">
                <span class="text-3xl">🌐</span>
                <div>
                    <div class="font-bold text-text-primary">Site public</div>
                    <div class="text-xs text-text-secondary">Retour à la page d'accueil</div>
                </div>
            </div>
            <div class="mt-auto">
                <span class="text-[10px] font-bold uppercase tracking-widest px-2.5 py-1 rounded-lg border border-custom text-text-secondary">Voir →</span>
            </div>
        </a>

    </div>
</div>

{# Modale membres inscrits — répartition actifs / suspendus #}
{% set usersPageUrl = path('app_admin_user_index') %}
<div id="members-stats-modal" class="fixed inset-0 z-[9999] hidden items-center justify-center" role="dialog" aria-modal="true" aria-labelledby="members-stats-title">
    <div id="members-stats-overlay" class="absolute inset-0 bg-black/80 backdrop-blur-sm"></div>
    <div id="members-stats-panel" role="link" tabindex="0" data-href="{{ usersPageUrl }}"
         class="relative z-10 w-full max-w-md mx-4 rounded-2xl border border-custom bg-custom-secondary shadow-2xl overflow-hidden hover:border-custom-orange transition-colors cursor-pointer">
        <div class="bg-custom-tertiary px-6 py-4 border-b border-custom flex items-center justify-between">
            <div>
                <span class="text-[9px] font-bold uppercase tracking-widest text-custom-orange">Comptes</span>
                <h2 id="members-stats-title" class="text-lg font-bold text-text-primary uppercase tracking-wide">Membres inscrits</h2>
            </div>
            <button id="members-stats-close" type="button" class="text-text-secondary hover:text-text-primary transition-colors p-1" aria-label="Fermer">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
        </div>
        <div class="px-6 py-5 flex flex-col gap-4">
            <p class="text-xs text-text-secondary">Répartition des comptes</p>
            <div class="flex items-center justify-between gap-3 rounded-xl border border-custom bg-custom-tertiary/50 px-4 py-3">
                <div>
                    <div class="text-[10px] font-bold uppercase tracking-wider text-text-secondary">Membres actifs</div>
                    <div class="text-xs text-text-secondary mt-0.5">Comptes non suspendus</div>
                </div>
                <span class="text-2xl font-extrabold text-emerald-400">{{ totalUsers|default(0) }}</span>
            </div>
            <div class="flex items-center justify-between gap-3 rounded-xl border border-custom bg-custom-tertiary/50 px-4 py-3">
                <div>
                    <div class="text-[10px] font-bold uppercase tracking-wider text-text-secondary">Membres suspendus</div>
                    <div class="text-xs text-text-secondary mt-0.5">Comptes suspendus</div>
                </div>
                <span class="text-2xl font-extrabold text-red-400">{{ inactiveUsers|default(0) }}</span>
            </div>
        </div>
    </div>
</div>

<script>
(function () {
    const modal = document.getElementById('members-stats-modal');
    const openBtn = document.getElementById('members-stats-open');
    const openCount = document.getElementById('members-stats-open-count');
    const closeBtn = document.getElementById('members-stats-close');
    const overlay = document.getElementById('members-stats-overlay');
    const panel = document.getElementById('members-stats-panel');
    if (!modal || !openBtn) return;

    function openModal() {
        modal.classList.remove('hidden');
        modal.classList.add('flex');
    }
    function closeModal() {
        modal.classList.add('hidden');
        modal.classList.remove('flex');
    }
    function goToUsers() {
        const href = panel && panel.getAttribute('data-href');
        if (href) window.location.href = href;
    }

    openBtn.addEventListener('click', openModal);
    if (openCount) openCount.addEventListener('click', openModal);
    if (closeBtn) {
        closeBtn.addEventListener('click', function (e) {
            e.preventDefault();
            e.stopPropagation();
            closeModal();
        });
    }
    if (overlay) overlay.addEventListener('click', closeModal);
    if (panel) {
        panel.addEventListener('click', function (e) {
            if (e.target.closest('#members-stats-close')) return;
            goToUsers();
        });
        panel.addEventListener('keydown', function (e) {
            if (e.key === 'Enter' || e.key === ' ') {
                e.preventDefault();
                goToUsers();
            }
        });
    }
    document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape' && !modal.classList.contains('hidden')) {
            closeModal();
        }
    });
})();
</script>
{% endblock %}
