<div id="mobile-menu-drawer" class="fixed inset-0 z-[95] lg:hidden pointer-events-none" aria-hidden="true">
	<div id="mobile-menu-overlay" class="absolute inset-0"></div>
	<div id="mobile-menu-content" class="mobile-menu-panel absolute top-0 right-0 bottom-0 w-[min(100%,340px)] max-w-[88vw] flex flex-col overflow-hidden">
		<div class="mobile-menu-panel__glow" aria-hidden="true"></div>
		<div class="mobile-menu-panel__edge" aria-hidden="true"></div>

		<div class="relative flex-1 min-h-0 overflow-y-auto overscroll-contain px-6 sm:px-7 pt-[5.25rem] pb-[max(1.5rem,env(safe-area-inset-bottom))]">
			<header class="mobile-menu-header mb-7">
				<span class="mobile-menu-header__eyebrow">Navigation</span>
				{% if app.user %}
					<p class="mobile-menu-header__welcome">Bienvenue <span>{{ app.user.username }}</span></p>
				{% else %}
					<p class="mobile-menu-header__welcome">La Boîte à Chimère</p>
				{% endif %}
			</header>

			<nav class="mobile-menu-nav flex flex-col" aria-label="Navigation mobile">
				<a href="{{ path('app_home') }}" data-turbo="false" class="mobile-nav-link {{ app.request.attributes.get('_route') == 'app_home' ? 'is-active' : '' }}" style="--i:0">Accueil</a>
				<a href="{{ path('app_jds') }}" data-turbo="false" class="mobile-nav-link {{ app.request.attributes.get('_route') == 'app_jds' ? 'is-active' : '' }}" style="--i:1">JDS</a>
				<a href="{{ path('app_jdr') }}" data-turbo="false" class="mobile-nav-link {{ app.request.attributes.get('_route') == 'app_jdr' ? 'is-active' : '' }}" style="--i:2">JDR</a>
				<a href="{{ path('app_gn') }}" data-turbo="false" class="mobile-nav-link {{ app.request.attributes.get('_route') == 'app_gn' ? 'is-active' : '' }}" style="--i:3">GN</a>
				<a href="{{ path('app_association') }}" data-turbo="false" class="mobile-nav-link {{ app.request.attributes.get('_route') == 'app_association' ? 'is-active' : '' }}" style="--i:4">Association</a>
				<a href="https://laboiteachimere.com/forum/" target="_blank" rel="noopener noreferrer" data-turbo="false" class="mobile-nav-link" style="--i:5">Forum</a>
				{% if app.user %}
					<a href="{{ path('app_user_dashboard') }}" data-turbo="false" class="mobile-nav-link {{ app.request.attributes.get('_route') == 'app_user_dashboard' ? 'is-active' : '' }}" style="--i:6">Mon espace</a>
				{% endif %}
				{% if is_granted('ROLE_ADMIN') %}
					<a href="{{ path('admin') }}" class="mobile-nav-link mobile-nav-link--accent {{ app.request.attributes.get('_route') starts with 'admin' or app.request.attributes.get('_route') starts with 'app_admin' or app.request.attributes.get('_route') starts with 'app_activity' ? 'is-active' : '' }}" style="--i:7">Dashboard</a>
				{% endif %}
			</nav>

			<div class="mobile-menu-footer mt-8 pt-6">
				{% if app.user %}
					<form id="mobile-logout-form" method="post" action="{{ path('app_logout') }}" data-turbo="false">
						<input type="hidden" name="_csrf_token" value="{{ csrf_token('logout') }}">
						<button type="submit" class="mobile-menu-cta">
							Déconnexion
						</button>
					</form>
				{% else %}
					<button id="mobile-join-btn" type="button" class="mobile-menu-cta">
						Nous rejoindre
					</button>
					<div id="mobile-join-form" class="overflow-hidden" style="max-height:0;transition:max-height 0.3s ease">
						{% if login_error is defined and login_error %}<p class="mb-2 text-xs font-semibold text-red-400 text-center">{{ login_error.messageKey|trans(login_error.messageData, 'security') }}</p>{% endif %}
						<form action="{{ path('app_login') }}" method="post" data-turbo="false" class="flex flex-col gap-3 pt-4">
							<input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
							<div>
								<label for="mobile-join-username" class="block text-xs font-bold uppercase tracking-wider text-text-secondary mb-1">Email</label>
								<input type="email" id="mobile-join-username" name="_username" value="{{ last_username|default('') }}" class="w-full rounded-lg border border-custom bg-custom-tertiary px-4 py-2.5 text-sm text-text-primary placeholder-text-secondary/60 focus:border-custom-orange focus:outline-none focus:ring-1 focus:ring-custom-orange {{ (login_error is defined and login_error) ? 'border-red-500' : '' }}" placeholder="votre@email.com" autocomplete="email">
							</div>
							<div>
								<label for="mobile-join-password" class="block text-xs font-bold uppercase tracking-wider text-text-secondary mb-1">Mot de passe</label>
								<div class="relative">
									<input type="password" id="mobile-join-password" name="_password" class="w-full rounded-lg border border-custom bg-custom-tertiary px-4 py-2.5 pr-10 text-sm text-text-primary placeholder-text-secondary/60 focus:border-custom-orange focus:outline-none focus:ring-1 focus:ring-custom-orange" placeholder="········" autocomplete="current-password">
									<button type="button" data-toggle-password="mobile-join-password" class="absolute right-3 top-1/2 -translate-y-1/2 text-text-secondary hover:text-custom-orange hover:scale-110 transition-all cursor-pointer" tabindex="-1" aria-label="Afficher le mot de passe">
										<svg class="w-5 h-5 eye-closed" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/></svg>
										<svg class="w-5 h-5 eye-open hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
									</button>
								</div>
							</div>
							<button type="submit" class="mobile-menu-cta mobile-menu-cta--compact">Se connecter</button>
							<button type="button" data-open-register class="mobile-menu-cta mobile-menu-cta--compact">S'inscrire</button>
							<a href="{{ path('app_forgot_password_request') }}" class="block text-center text-xs text-text-secondary hover:text-custom-orange transition-colors mt-1">Mot de passe oublié ?</a>
						</form>
					</div>
				{% endif %}

				<p class="mobile-menu-copy">&copy; {{ "now"|date("Y") }} La Boîte à Chimère</p>
			</div>
		</div>
	</div>
</div>
