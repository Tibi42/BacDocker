{# Affiche une note sur 5 étoiles (toujours visibles ; vides si pas encore noté).
   Variables :
     rating     float|int|null
     size       string  classes taille du conteneur (défaut text-sm)
     interactive bool   si true, n'affiche que le rendu (les boutons sont hors composant)
#}
{% set score = rating is not null ? rating|round : 0 %}
{% set size = size|default('text-sm') %}
{% set starClass = size starts with 'text-' ? size : 'text-sm' %}
<span class="inline-flex items-center gap-px {{ starClass }} leading-none shrink-0" title="{% if rating is not null %}{{ rating|number_format(1) }} / 5{% else %}Pas encore noté{% endif %}" aria-label="{% if rating is not null %}Note {{ rating|number_format(1) }} sur 5{% else %}Pas encore noté{% endif %}">
	{% for i in 1..5 %}
		<svg class="h-[1em] w-[1em] {{ i <= score ? 'text-amber-400' : 'text-gray-500' }}" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
			<path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
		</svg>
	{% endfor %}
</span>
