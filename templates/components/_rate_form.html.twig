{# Formulaire de notation interactive (1–5 étoiles).
   Variables :
     ratePath   string  URL d'action POST
     csrfId     string  id du token CSRF (ex: 'admin_rate_game' ~ id)
     myScore    int     note actuelle de l'utilisateur (0 si aucune)
     label      string  libellé optionnel (défaut "Noter" / "Ma note")
     returnTo   string  optionnel : valeur du champ hidden "return" (ex: edit)
#}
{% set myScore = myScore|default(0) %}
<form method="post" action="{{ ratePath }}" class="flex flex-col gap-0.5">
	<input type="hidden" name="_token" value="{{ csrf_token(csrfId) }}">
	{% if returnTo is defined and returnTo %}
		<input type="hidden" name="return" value="{{ returnTo }}">
	{% endif %}
	<span class="text-[9px] font-bold uppercase tracking-wider text-text-secondary">{{ label|default(myScore ? 'Ma note' : 'Noter') }}</span>
	<div class="inline-flex items-center gap-0.5" role="group" aria-label="Noter sur 5 étoiles">
		{% for value in 1..5 %}
			<button type="submit" name="rating" value="{{ value }}" title="{{ value }} / 5" aria-label="Donner {{ value }} étoile{{ value > 1 ? 's' : '' }}" class="p-0.5 leading-none transition-transform hover:scale-110 {{ value <= myScore ? 'text-amber-400' : 'text-gray-500 hover:text-amber-400/70' }}">
				<svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
					<path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
				</svg>
			</button>
		{% endfor %}
	</div>
</form>
