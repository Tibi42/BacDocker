{# Macro pour la couleur d'un jour du calendrier selon le type d'activité #}
{# isPast = true → version grisée pour les jours passés #}
{% macro day_classes(actType, isPast) %}
{%- if isPast -%}
calendar-day-past
{%- elseif actType == 'JDS' -%}
calendar-day-event--jds
{%- elseif actType == 'JDR' -%}
calendar-day-event--jdr
{%- elseif actType == 'GN' -%}
calendar-day-event--gn
{%- elseif actType == 'JDF' -%}
calendar-day-event--jdf
{%- elseif actType == 'AG' -%}
calendar-day-event--ag
{%- else -%}
calendar-day-event--default
{%- endif -%}
{% endmacro %}

{# Conservé pour compatibilité ; le style est désormais porté par les classes day_classes #}
{% macro day_text_classes(actType, isPast) %}
{% endmacro %}
