# Copier ce fichier vers .env.docker.local avant le premier lancement :
#   cp .env.docker.local.dist .env.docker.local
#
# Les valeurs ci-dessous sont utilisées par docker compose (voir compose.yaml / compose.prod.yaml).

###> Application ###
APP_ENV=dev
APP_DEBUG=1
# Générer avec : php -r "echo bin2hex(random_bytes(32)), PHP_EOL;"
APP_SECRET=change_me_generate_a_random_secret
DEFAULT_URI=http://localhost:8080
###< Application ###

###> Base de données MySQL (service database) ###
MYSQL_ROOT_PASSWORD=changeme
MYSQL_DATABASE=bacbdd
MYSQL_USER=app
MYSQL_PASSWORD=changeme
###< Base de données MySQL ###

###> Mail (Mailpit en local ; OVH en vrai prod) ###
MAILER_DSN=smtp://mailer:1025
MAILER_FROM=boiteachimere@guillaumepecquet.ovh
MAILER_FROM_NAME="La Boîte à Chimère"
# Prod OVH :
# MAILER_DSN=smtp://boiteachimere%40guillaumepecquet.ovh:MOT_DE_PASSE@ssl0.ovh.net:465
###< Mail ###

###> Démarrage automatique ###
# Mettre à 1 pour lancer les migrations à chaque démarrage du conteneur PHP
RUN_MIGRATIONS=0
###< Démarrage automatique ###

###> Xdebug (stage dev du Dockerfile) ###
# Activer : XDEBUG_MODE=debug
XDEBUG_MODE=off
XDEBUG_CONFIG=client_host=host.docker.internal
###< Xdebug ###
